---
import "../styles/global.css";
import MetaPixel from "../components/MetaPixel.astro";

const siteUrl = new URL(Astro.url.pathname, "https://growspaces.co").href;
const title = "Flexible Workspace Marketing Agency | Spaces Agency";
const description = "Marketing and growth for coworking spaces, serviced offices, and hot desk providers. Web design, local SEO, Google Ads, and Meta campaigns that fill desks. Trusted by independent operators across the UK.";
const ogImage = `https://growspaces.co/images/og-image.jpg`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts: Fraunces (heading) + DM Sans (body) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
			rel="stylesheet"
		/>

		<!-- Primary meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content="Spaces Agency | Marketing That Fills Flexible Workspaces" />
		<meta property="og:description" content="Web design, local SEO, and paid ads built for coworking spaces, serviced offices, and hot desk providers. Trusted by independent operators across the UK." />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="en_GB" />
		<meta property="og:site_name" content="Spaces Agency" />

		<!-- Twitter / X card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- 100% privacy-first analytics -->
		<script is:inline async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>

		<!-- Meta Pixel -->
		<MetaPixel />
	</head>
	<body class="antialiased">
		<slot />
	</body>
</html>
