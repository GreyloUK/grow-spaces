---
import "../styles/global.css";

const siteUrl = "https://growspaces.co";
const title = "Free Google Business Profile Audit | Spaces Agency";
const description = "Find out why your coworking space isn't showing up on Google Maps. Get a free, personalised audit with specific fixes you can action today.";
const ogImage = `${siteUrl}/images/og-image.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- No-index: standalone ad landing page -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Google Fonts: Fraunces (heading) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
      rel="stylesheet"
    />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/gbp-audit/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Spaces Agency" />

    <!-- 100% privacy-first analytics -->
    <script is:inline async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>

    <!-- Meta Pixel Code -->
    <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '932158652926055');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=932158652926055&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body class="antialiased">

    <!-- Navbar: logo only -->
    <header class="bg-background/90 sticky top-0 z-50 border-b border-border/60 backdrop-blur-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-center px-4 py-4 sm:px-6">
        <a href="/" class="shrink-0">
          <img src="/logo.svg" alt="Spaces Agency" class="h-14 w-auto" />
        </a>
      </div>
    </header>

    <main>

      <!-- Hero + Form -->
      <section class="bg-background py-16 sm:py-20 lg:py-24">
        <div class="mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:items-start">

          <!-- Left: copy -->
          <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-5">
              <h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl lg:leading-[1.15]">
                Find out exactly why your coworking space isn't showing up on Google&nbsp;Maps
              </h1>
              <p class="text-lg text-muted-foreground sm:text-xl">
                Get a free, personalised audit of your Google Business Profile, with specific fixes you can action today.
              </p>
            </div>

            <!-- Value points -->
            <ul class="flex flex-col gap-5">
              <li class="flex items-start gap-3">
                <span class="mt-1 flex size-8 shrink-0 items-center justify-center rounded-full bg-accent/15 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
                </span>
                <span class="text-foreground">See how you compare to competitors in your local area on Google Maps</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 flex size-8 shrink-0 items-center justify-center rounded-full bg-accent/15 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
                </span>
                <span class="text-foreground">Get a list of specific issues hurting your visibility, and how to fix them</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 flex size-8 shrink-0 items-center justify-center rounded-full bg-accent/15 text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </span>
                <span class="text-foreground">Understand where your direct enquiries are leaking to aggregators like Coworker.com</span>
              </li>
            </ul>
          </div>

          <!-- Right: form -->
          <div class="flex flex-col gap-5 rounded-2xl border border-border bg-card p-6 shadow-sm sm:p-8">
            <h2 class="font-heading text-xl font-semibold text-foreground sm:text-2xl">
              Get your free audit
            </h2>
            <form id="audit-form" action="https://formspree.io/f/mbdpeqrw" method="POST" class="flex flex-col gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="first-name" class="text-sm font-medium text-foreground">First name</label>
                <input
                  type="text"
                  id="first-name"
                  name="firstName"
                  required
                  placeholder="Jane"
                  class="h-10 w-full rounded-lg border border-input bg-transparent px-3 text-base transition-colors outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="text-sm font-medium text-foreground">Email address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@workspace.co"
                  class="h-10 w-full rounded-lg border border-input bg-transparent px-3 text-base transition-colors outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="space-name" class="text-sm font-medium text-foreground">Coworking space name</label>
                <input
                  type="text"
                  id="space-name"
                  name="spaceName"
                  required
                  placeholder="The Hive"
                  class="h-10 w-full rounded-lg border border-input bg-transparent px-3 text-base transition-colors outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="city" class="text-sm font-medium text-foreground">City / town</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  required
                  placeholder="Manchester"
                  class="h-10 w-full rounded-lg border border-input bg-transparent px-3 text-base transition-colors outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
                />
              </div>
              <button
                type="submit"
                class="mt-2 inline-flex h-11 cursor-pointer items-center justify-center rounded-full bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-none"
              >
                Get my free audit
              </button>
            </form>
            <p class="text-center text-sm text-muted-foreground">
              No commitment. The audit is yours to keep whether you work with us or not.
            </p>
          </div>

        </div>
      </section>

      <!-- Proof section -->
      <section class="border-t border-border bg-muted/40 py-16 sm:py-20">
        <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 px-4 text-center sm:px-6">
          <div class="flex items-center gap-1">
            {[...Array(5)].map(() => (
              <svg class="size-5 text-amber-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <blockquote class="font-heading text-xl font-medium text-foreground sm:text-2xl lg:text-3xl lg:leading-snug">
            We built a coworking space's Google presence from scratch. Zero reviews, no listing. Now they're <span class="text-primary">#1 on Google Maps</span> with <span class="text-primary">13 five-star reviews</span>.
          </blockquote>
          <p class="text-muted-foreground">
            No ad spend. Just Google Business Profile optimisation and local SEO.
          </p>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-border py-8">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 sm:px-6">
        <a href="/" class="shrink-0">
          <img src="/logo.svg" alt="Spaces Agency" class="h-10 w-auto" />
        </a>
        <div class="flex items-center gap-3 text-sm text-muted-foreground">
          <span>&copy; 2026 Spaces Agency</span>
          <span class="text-border">|</span>
          <a href="/privacy/" class="hover:text-foreground transition-colors">Privacy policy</a>
        </div>
      </div>
    </footer>

    <!-- Formspree submission with inline success state -->
    <script>
      const form = document.getElementById('audit-form') as HTMLFormElement;
      const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const data = new FormData(form);

        button.disabled = true;
        button.textContent = 'Sending...';

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });

          if (!res.ok) throw new Error('Form submission failed');

          // Fire Meta Lead conversion event
          if (typeof (window as any).fbq === 'function') (window as any).fbq('track', 'Lead');

          form.innerHTML = `
            <div class="flex flex-col items-center gap-3 py-4 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <p class="font-heading text-xl font-semibold text-foreground">You're in!</p>
              <p class="text-muted-foreground">We'll send your personalised audit within 48 hours.</p>
            </div>
          `;
        } catch {
          button.disabled = false;
          button.textContent = 'Get my free audit';
          alert('Something went wrong. Please try again.');
        }
      });
    </script>

  </body>
</html>
