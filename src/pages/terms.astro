    <p class="text-muted-foreground mt-3 text-sm">Last updated: 10 April 2026</p>

    <div class="prose mt-12 max-w-none space-y-10 text-foreground/90 [&_h2]:font-heading [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-foreground [&_h2]:sm:text-2xl [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:leading-relaxed [&_li]:mt-1.5">

      <section>
