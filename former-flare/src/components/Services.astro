---
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";

const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
    title: "Web Design",
    description: "A fast, conversion-focused website built to turn visitors into enquiries — tailored to your space and location.",
    tag: "Convert",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Local SEO",
    description: "Rank for high-intent searches in your area. We handle technical SEO, content, and Google Business — sustainably.",
    tag: "Be Found",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>`,
    title: "Paid Ads (PPC)",
    description: "Google and Meta campaigns that target people actively looking for coworking in your city — with ROI you can see.",
    tag: "Scale Fast",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    title: "Member Workflows",
    description: "Automated email and CRM sequences that move leads from first enquiry to signed membership — without manual effort.",
    tag: "Automate",
  },
];
---

<section id="services" class="bg-muted/40 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">

    <!-- Header -->
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-primary">What We Do</p>
      <h2 class="font-heading mb-4 text-4xl font-semibold tracking-tight text-foreground md:text-5xl">
        Everything your space needs to grow
      </h2>
      <p class="text-lg text-muted-foreground">
        One partner. One system. Built specifically for independent coworking operators.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <Card className="group relative rounded-2xl border border-border ring-0 gap-0 py-0 transition-all hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5">
          <CardContent className="flex flex-col p-7">
            <!-- Tag -->
            <Badge className="mb-5 w-fit h-auto rounded-full border-transparent bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {service.tag}
            </Badge>

            <!-- Icon -->
            <div class="mb-4 text-primary" set:html={service.icon} />

            <!-- Content -->
            <h3 class="font-heading mb-2 text-lg font-semibold text-foreground">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed text-muted-foreground">
              {service.description}
            </p>
          </CardContent>

          <!-- Hover accent line -->
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-primary opacity-0 transition-opacity group-hover:opacity-100"></div>
        </Card>
      ))}
    </div>
  </div>
</section>
